<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>CompRent | Wypożyczalnia laptopów</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, sans-serif;
            background: #f4f6fa;
            color: #1a2c3e;
            line-height: 1.4;
        }

        .navbar {
            background: white;
            padding: 14px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            border-bottom: 1px solid #e9edf2;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
        }

        .logo-icon {
            width: 42px;
            height: 42px;
            position: relative;
        }

        .ball {
            position: absolute;
            border-radius: 50%;
        }

        .ball1 { width: 18px; height: 18px; background: #ff6b9d; top: 0; left: 50%; transform: translateX(-50%); }
        .ball2 { width: 16px; height: 16px; background: #ffb347; bottom: 2px; left: 2px; }
        .ball3 { width: 16px; height: 16px; background: #6c5ce7; bottom: 2px; right: 2px; }
        .ball4 { width: 14px; height: 14px; background: #00cec9; top: 10px; left: 2px; }
        .ball5 { width: 14px; height: 14px; background: #fd79a8; top: 10px; right: 2px; }
        .center-dot { width: 20px; height: 20px; background: white; border-radius: 50%; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }

        .logo-text {
            font-size: 24px;
            font-weight: 700;
            color: #1f6392;
            letter-spacing: -0.3px;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .nav-link {
            background: none;
            border: none;
            font-size: 15px;
            font-weight: 500;
            color: #4a627a;
            cursor: pointer;
            transition: color 0.2s;
        }

        .nav-link:hover { color: #1f6392; }

        .user-badge {
            display: flex;
            align-items: center;
            gap: 16px;
            background: #f0f4fa;
            padding: 6px 20px;
            border-radius: 40px;
        }

        .logout-btn {
            background: none;
            border: none;
            color: #c2412c;
            font-weight: 500;
            cursor: pointer;
        }

        .container {
            max-width: 1440px;
            margin: 0 auto;
            padding: 28px 32px;
        }

        .search-wrapper {
            margin-bottom: 32px;
        }

        .search-input {
            width: 100%;
            padding: 14px 20px;
            border-radius: 60px;
            border: 1px solid #dce3ec;
            background: white;
            font-size: 16px;
            transition: all 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: #1f6392;
            box-shadow: 0 0 0 3px rgba(31,99,146,0.1);
        }

        .shop-layout {
            display: flex;
            gap: 32px;
            flex-wrap: wrap;
        }

        .filter-panel {
            width: 300px;
            background: white;
            border-radius: 28px;
            padding: 24px;
            border: 1px solid #eef2f8;
            height: fit-content;
            position: sticky;
            top: 90px;
        }

        .filter-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #edf2f7;
        }

        .filter-header h3 {
            font-size: 18px;
            font-weight: 600;
        }

        .clear-filters {
            background: none;
            border: none;
            color: #1f6392;
            font-size: 13px;
            cursor: pointer;
            font-weight: 500;
        }

        .filter-section {
            margin-bottom: 24px;
            border-bottom: 1px solid #f0f4f9;
            padding-bottom: 20px;
        }

        .filter-section label {
            font-weight: 600;
            font-size: 14px;
            display: block;
            margin-bottom: 12px;
            color: #2c3e50;
        }

        .filter-select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 40px;
            border: 1px solid #dce3ec;
            background: white;
            font-size: 14px;
        }

        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: normal;
            font-size: 14px;
            cursor: pointer;
        }

        .price-range {
            display: flex;
            gap: 12px;
        }

        .price-range input {
            width: 50%;
            padding: 10px;
            border-radius: 40px;
            border: 1px solid #dce3ec;
        }

        .products-grid {
            flex: 1;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
        }

        .product-card {
            background: white;
            border-radius: 24px;
            padding: 20px;
            border: 1px solid #eef2f8;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.1);
        }

        .product-name {
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .product-specs {
            font-size: 13px;
            color: #5b6e8c;
            margin: 8px 0;
        }

        .product-price {
            font-size: 22px;
            font-weight: 700;
            color: #1f6392;
            margin-top: 12px;
        }

        .no-results {
            flex: 1;
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 28px;
            color: #6c7f96;
        }

        .breadcrumb {
            font-size: 14px;
            color: #6c7f96;
            margin-bottom: 24px;
        }

        .breadcrumb span {
            cursor: pointer;
        }

        .breadcrumb span:hover {
            color: #1f6392;
            text-decoration: underline;
        }

        .product-detail-card {
            background: white;
            border-radius: 32px;
            padding: 32px;
            margin-bottom: 32px;
        }

        .product-detail-header {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 24px;
            margin-bottom: 28px;
        }

        .product-detail-title {
            font-size: 28px;
            font-weight: 700;
        }

        .rating {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

        .stars {
            color: #f5b042;
            font-size: 18px;
            letter-spacing: 2px;
        }

        .detail-price {
            font-size: 36px;
            font-weight: 800;
            color: #1f6392;
        }

        .rent-button {
            background: #1f6392;
            border: none;
            padding: 12px 36px;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: 0.2s;
        }

        .rent-button:hover {
            background: #0f4a6e;
        }

        .specs-table {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
            background: #f8fafd;
            padding: 20px;
            border-radius: 24px;
            margin: 24px 0;
        }

        .spec-item {
            font-size: 14px;
        }

        .spec-label {
            font-weight: 700;
            color: #2c3e50;
        }

        .product-description {
            line-height: 1.6;
            margin: 24px 0;
        }

        .reviews-block {
            background: white;
            border-radius: 32px;
            padding: 32px;
        }

        .review-item {
            border-bottom: 1px solid #eef2f8;
            padding: 20px 0;
        }

        .profile-card {
            background: white;
            border-radius: 32px;
            padding: 32px;
        }

        .profile-tabs {
            display: flex;
            gap: 28px;
            border-bottom: 1px solid #eef2f8;
            margin-bottom: 28px;
        }

        .profile-tab {
            background: none;
            border: none;
            padding: 12px 0;
            font-size: 16px;
            font-weight: 500;
            color: #6c7f96;
            cursor: pointer;
        }

        .profile-tab.active {
            color: #1f6392;
            border-bottom: 2px solid #1f6392;
        }

        .form-double {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 28px;
        }

        .input-field {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .input-field label {
            font-size: 13px;
            font-weight: 600;
        }

        .input-field input {
            padding: 12px 16px;
            border-radius: 24px;
            border: 1px solid #dce3ec;
            font-size: 14px;
        }

        .save-button {
            background: #1f6392;
            padding: 10px 28px;
            border: none;
            border-radius: 40px;
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

        .password-change {
            margin-top: 32px;
            padding-top: 24px;
            border-top: 1px solid #eef2f8;
        }

        /* styl dla auth */
        .auth-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #eef2f5;
            padding: 20px;
        }

        .auth-card {
            background: white;
            padding: 40px;
            border-radius: 32px;
            width: 100%;
            max-width: 520px;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.08);
        }

        .auth-logo {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            position: relative;
        }

        .auth-title {
            text-align: center;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 28px;
            color: #1a2c3e;
        }

        .auth-input {
            width: 100%;
            padding: 14px 18px;
            border-radius: 30px;
            border: 1px solid #dce3ec;
            font-size: 15px;
            margin-bottom: 16px;
        }

        .auth-input:focus {
            outline: none;
            border-color: #1f6392;
        }

        .auth-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
        }

        .auth-checkbox {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 16px 0;
            font-size: 13px;
            color: #4a627a;
        }

        .auth-btn {
            width: 100%;
            background: #1f6392;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 14px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            margin-top: 8px;
        }

        .auth-back {
            width: 100%;
            background: none;
            border: none;
            color: #6c7f96;
            margin-top: 16px;
            cursor: pointer;
            text-align: center;
        }

        .error-msg {
            color: #c2412c;
            text-align: center;
            margin-top: 16px;
            font-size: 14px;
        }

        @media (max-width: 800px) {
            .filter-panel { width: 100%; position: static; }
            .container { padding: 20px; }
            .navbar { padding: 12px 20px; }
            .auth-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<div id="app"></div>

<script>
    // ---------- DANE PRODUKTÓW ----------
    const LAPTOPS = [
        { id:1, name:"Acer Nitro V 16 AI", subtitle:"16″ IPS 180Hz · R5-240 · 16GB · 1TB SSD · RTX4050", specs:{ procesor:"AMD Ryzen 5 240", ram:"16GB", dysk:"1TB SSD", karta:"RTX 4050", ekran:"16″ IPS 180Hz", system:"Windows 11" }, price:374, rating:4.5, brand:"Acer", ram:"16GB", storage:"1TB", gpu:"RTX 4050", screen:"16″", reviews:[{ author:"Kamil", rating:5, text:"Świetny gaming, ekran 180Hz rewelacja." },{ author:"Anna", rating:4, text:"Dobry do pracy, ale wentylatory słychać." }], description:"Acer Nitro V 16 AI – idealny dla graczy i twórców. RTX 4050 i 180Hz dają płynność w każdej sytuacji." },
        { id:2, name:"Apple MacBook Neo 2026", subtitle:"13″ Retina · A18 Pro · 8GB · 512GB", specs:{ procesor:"Apple A18 Pro", ram:"8GB", dysk:"512GB SSD", karta:"Apple GPU", ekran:"13″ Retina", system:"macOS" }, price:291, rating:4.8, brand:"Apple", ram:"8GB", storage:"512GB", gpu:"Integrated", screen:"13″", reviews:[{ author:"Magda", rating:5, text:"Lekki, szybki, bateria na długo." }], description:"MacBook Neo z A18 Pro – wydajność i styl w jednym." },
        { id:3, name:"Lenovo IdeaPad Slim 5", subtitle:"16″ IPS · R7-7735HS · 32GB · 512GB", specs:{ procesor:"AMD Ryzen 7 7735HS", ram:"32GB", dysk:"512GB SSD", karta:"AMD Radeon 680M", ekran:"16″ IPS", system:"Windows 11" }, price:291, rating:4.2, brand:"Lenovo", ram:"32GB", storage:"512GB", gpu:"AMD Radeon", screen:"16″", reviews:[], description:"Świetny do wielozadaniowości i multimediów." },
        { id:4, name:"Apple MacBook Air 2026", subtitle:"15.3″ Retina · M5 · 16GB · 512GB", specs:{ procesor:"Apple M5", ram:"16GB", dysk:"512GB SSD", karta:"Apple M5", ekran:"15.3″ Liquid Retina", system:"macOS" }, price:541, rating:4.9, brand:"Apple", ram:"16GB", storage:"512GB", gpu:"Integrated", screen:"15.3″", reviews:[], description:"Najlepszy Air w historii – wydajność i czas pracy." },
        { id:5, name:"Asus Vivobook 15", subtitle:"15.6″ IPS · Core 5 120U · 16GB · 512GB", specs:{ procesor:"Intel Core 5 120U", ram:"16GB", dysk:"512GB SSD", karta:"Intel Graphics", ekran:"15.6″ IPS", system:"Windows 11" }, price:208, rating:4.0, brand:"Asus", ram:"16GB", storage:"512GB", gpu:"Intel", screen:"15.6″", reviews:[], description:"Ekonomiczny laptop do codziennych zadań." },
        { id:6, name:"Dell XPS 15", subtitle:"15.6″ OLED · i7 · 32GB · 1TB · RTX4060", specs:{ procesor:"Intel i7", ram:"32GB", dysk:"1TB SSD", karta:"RTX 4060", ekran:"15.6″ OLED", system:"Windows 11" }, price:489, rating:4.7, brand:"Dell", ram:"32GB", storage:"1TB", gpu:"RTX 4060", screen:"15.6″", reviews:[], description:"Premium, ekran OLED, idealny do grafiki." },
        { id:7, name:"HP Spectre x360", subtitle:"14″ OLED · i7 · 16GB · 1TB", specs:{ procesor:"Intel i7", ram:"16GB", dysk:"1TB SSD", karta:"Intel Iris", ekran:"14″ OLED", system:"Windows 11" }, price:399, rating:4.4, brand:"HP", ram:"16GB", storage:"1TB", gpu:"Intel Iris", screen:"14″", reviews:[], description:"Konwertowalny 2w1, dotykowy, premium." }
    ];

    // ---------- STAN APLIKACJI ----------
    let currentView = 'shop';
    let selectedProduct = null;
    let filters = {
        brand: '', ram: [], storage: [], gpu: [], screen: [], minPrice: '', maxPrice: '', search: ''
    };

    // ---------- AUTH ----------
    function initDB() {
        if (!localStorage.getItem('users')) {
            localStorage.setItem('users', JSON.stringify([
                { id: 1, email: "admin@comprent.pl", password: "admin123", name: "Jan", surname: "Kowalski", phone: "123456789", address: "ul. Kwiatowa 8", postal: "00-001", role: "user" }
            ]));
        }
        if (!localStorage.getItem('currentUser')) localStorage.removeItem('currentUser');
    }

    function getUsers() { return JSON.parse(localStorage.getItem('users')); }
    function saveUsers(u) { localStorage.setItem('users', JSON.stringify(u)); }
    function getCurrent() { return JSON.parse(localStorage.getItem('currentUser')); }
    function setCurrent(u) { localStorage.setItem('currentUser', JSON.stringify(u)); }
    function clearCurrent() { localStorage.removeItem('currentUser'); }

    // ---------- RENDER GŁÓWNY ----------
    function render() {
        const user = getCurrent();
        const root = document.getElementById('app');
        if (!user) { renderWelcome(root); }
        else {
            if (currentView === 'profile') renderProfile(root, user);
            else if (currentView === 'product' && selectedProduct) renderProductDetail(root, user, selectedProduct);
            else renderShop(root, user);
        }
    }

    // ========== POPRAWIONA REJESTRACJA ==========
    function renderWelcome(root) {
        root.innerHTML = `
            <div class="auth-container">
                <div class="auth-card">
                    <div class="auth-logo">
                        <div style="position:absolute; width:32px; height:32px; background:#ff6b9d; border-radius:50%; top:0; left:50%; transform:translateX(-50%);"></div>
                        <div style="position:absolute; width:28px; height:28px; background:#ffb347; border-radius:50%; bottom:5px; left:5px;"></div>
                        <div style="position:absolute; width:28px; height:28px; background:#6c5ce7; border-radius:50%; bottom:5px; right:5px;"></div>
                        <div style="position:absolute; width:24px; height:24px; background:#00cec9; border-radius:50%; top:15px; left:5px;"></div>
                        <div style="position:absolute; width:24px; height:24px; background:#fd79a8; border-radius:50%; top:15px; right:5px;"></div>
                        <div style="position:absolute; width:36px; height:36px; background:white; border-radius:50%; top:50%; left:50%; transform:translate(-50%,-50%);"></div>
                    </div>
                    <div class="auth-title">Welcome</div>
                    <div style="display:flex; gap:16px;">
                        <button id="loginBtn" class="auth-btn" style="background:#1f6392;">Log in</button>
                        <button id="signupBtn" class="auth-btn" style="background:transparent; border:1.5px solid #1f6392; color:#1f6392;">Sign up</button>
                    </div>
                </div>
            </div>
        `;
        document.getElementById('loginBtn')?.addEventListener('click', () => showLogin(root));
        document.getElementById('signupBtn')?.addEventListener('click', () => showSignup(root));
    }

    function showLogin(root) {
        root.innerHTML = `
            <div class="auth-container">
                <div class="auth-card">
                    <div class="auth-title">logowanie</div>
                    <input type="email" id="loginEmail" class="auth-input" placeholder="Email">
                    <input type="password" id="loginPassword" class="auth-input" placeholder="Hasło">
                    <button id="doLogin" class="auth-btn">Zaloguj się</button>
                    <button id="backToWelcome" class="auth-back">← Powrót</button>
                    <div id="loginError" class="error-msg"></div>
                </div>
            </div>
        `;
        document.getElementById('doLogin')?.addEventListener('click', () => {
            const email = document.getElementById('loginEmail').value;
            const pwd = document.getElementById('loginPassword').value;
            const user = getUsers().find(u => u.email === email && u.password === pwd);
            if (user) { setCurrent(user); currentView = 'shop'; render(); }
            else { document.getElementById('loginError').innerText = "❌ Błędny email lub hasło"; }
        });
        document.getElementById('backToWelcome')?.addEventListener('click', () => renderWelcome(root));
    }

    // POPRAWIONA REJESTRACJA – wszystkie pola, checkboxy, walidacja
    function showSignup(root) {
        root.innerHTML = `
            <div class="auth-container">
                <div class="auth-card">
                    <div class="auth-title">rejestracja</div>
                    
                    <div class="auth-row">
                        <input type="text" id="regName" class="auth-input" placeholder="Imię">
                        <input type="text" id="regSurname" class="auth-input" placeholder="Nazwisko">
                    </div>
                    
                    <input type="email" id="regEmail" class="auth-input" placeholder="Email">
                    <input type="tel" id="regPhone" class="auth-input" placeholder="Telefon">
                    <input type="text" id="regLocation" class="auth-input" placeholder="Lokalizacja (miasto)">
                    <input type="text" id="regAddress" class="auth-input" placeholder="Adres zamieszkania">
                    
                    <div class="auth-row">
                        <input type="password" id="regPassword" class="auth-input" placeholder="Hasło">
                        <input type="password" id="regConfirm" class="auth-input" placeholder="Potwierdź hasło">
                    </div>
                    
                    <div class="auth-checkbox">
                        <input type="checkbox" id="policyCheck">
                        <label>Zapoznałem/am się z Polityką prywatności i akceptuję jej warunki.</label>
                    </div>
                    <div class="auth-checkbox">
                        <input type="checkbox" id="termsCheck">
                        <label>Zapoznałem/am się z Regulaminem i akceptuję jego warunki.</label>
                    </div>
                    
                    <button id="doSignup" class="auth-btn">Zarejestruj się</button>
                    <button id="backToWelcome" class="auth-back">← Powrót</button>
                    <div id="signupError" class="error-msg"></div>
                </div>
            </div>
        `;
        
        document.getElementById('doSignup')?.addEventListener('click', () => {
            const name = document.getElementById('regName').value.trim();
            const surname = document.getElementById('regSurname').value.trim();
            const email = document.getElementById('regEmail').value.trim();
            const phone = document.getElementById('regPhone').value.trim();
            const location = document.getElementById('regLocation').value.trim();
            const address = document.getElementById('regAddress').value.trim();
            const password = document.getElementById('regPassword').value;
            const confirm = document.getElementById('regConfirm').value;
            const policyChecked = document.getElementById('policyCheck').checked;
            const termsChecked = document.getElementById('termsCheck').checked;
            
            // walidacja
            if (!name || !surname || !email || !password || !confirm) {
                document.getElementById('signupError').innerText = "❌ Wypełnij wszystkie wymagane pola (Imię, Nazwisko, Email, Hasło)";
                return;
            }
            if (password !== confirm) {
                document.getElementById('signupError').innerText = "❌ Hasła nie są identyczne";
                return;
            }
            if (password.length < 6) {
                document.getElementById('signupError').innerText = "❌ Hasło musi mieć co najmniej 6 znaków";
                return;
            }
            if (!policyChecked || !termsChecked) {
                document.getElementById('signupError').innerText = "❌ Musisz zaakceptować Politykę prywatności i Regulamin";
                return;
            }
            
            const users = getUsers();
            if (users.find(u => u.email === email)) {
                document.getElementById('signupError').innerText = "❌ Użytkownik z tym emailem już istnieje";
                return;
            }
            
            const newUser = {
                id: users.length + 1,
                email: email,
                password: password,
                name: name,
                surname: surname,
                phone: phone,
                location: location,
                address: address,
                postal: "",
                role: "user"
            };
            users.push(newUser);
            saveUsers(users);
            setCurrent(newUser);
            currentView = 'shop';
            render();
        });
        
        document.getElementById('backToWelcome')?.addEventListener('click', () => renderWelcome(root));
    }

    // ---------- STRONA GŁÓWNA Z FILTREM ----------
    function renderShop(root, user) {
        root.innerHTML = `
            <div class="navbar">
                <div class="logo-area" id="homeBtn"><div class="logo-icon"><div class="ball ball1"></div><div class="ball ball2"></div><div class="ball ball3"></div><div class="ball ball4"></div><div class="ball ball5"></div><div class="center-dot"></div></div><span class="logo-text">CompRent</span></div>
                <div class="nav-links"><button class="nav-link" id="profileNav">Profil</button><div class="user-badge"><span>👋 ${user.name} ${user.surname}</span><button id="logoutBtn" class="logout-btn">Wyloguj</button></div></div>
            </div>
            <div class="container">
                <div class="search-wrapper"><input type="text" id="globalSearch" class="search-input" placeholder="🔍 Szukaj laptopa (marka, procesor, nazwa...)" value="${escapeHtml(filters.search)}"></div>
                <div class="shop-layout">
                    <div class="filter-panel">
                        <div class="filter-header"><h3>Filtry</h3><button id="clearAllFilters" class="clear-filters">Wyczyść wszystko</button></div>
                        <div class="filter-section"><label>Marka</label><select id="brandSelect" class="filter-select"><option value="">Wszystkie</option><option>Acer</option><option>Apple</option><option>Lenovo</option><option>Asus</option><option>Dell</option><option>HP</option></select></div>
                        <div class="filter-section"><label>RAM</label><div class="checkbox-group"><label><input type="checkbox" value="8GB" class="ramFilter"> 8GB</label><label><input type="checkbox" value="16GB" class="ramFilter"> 16GB</label><label><input type="checkbox" value="32GB" class="ramFilter"> 32GB</label></div></div>
                        <div class="filter-section"><label>Dysk SSD</label><div class="checkbox-group"><label><input type="checkbox" value="512GB" class="storageFilter"> 512GB</label><label><input type="checkbox" value="1TB" class="storageFilter"> 1TB</label></div></div>
                        <div class="filter-section"><label>Karta graficzna</label><div class="checkbox-group"><label><input type="checkbox" value="RTX 4050" class="gpuFilter"> RTX 4050</label><label><input type="checkbox" value="RTX 4060" class="gpuFilter"> RTX 4060</label><label><input type="checkbox" value="AMD Radeon" class="gpuFilter"> AMD Radeon</label><label><input type="checkbox" value="Intel" class="gpuFilter"> Intel</label></div></div>
                        <div class="filter-section"><label>Ekran</label><div class="checkbox-group"><label><input type="checkbox" value="13″" class="screenFilter"> 13"</label><label><input type="checkbox" value="14″" class="screenFilter"> 14"</label><label><input type="checkbox" value="15.6″" class="screenFilter"> 15.6"</label><label><input type="checkbox" value="16″" class="screenFilter"> 16"</label></div></div>
                        <div class="filter-section"><label>Cena (zł/mies.)</label><div class="price-range"><input type="number" id="minPrice" placeholder="Od" value="${filters.minPrice}"><input type="number" id="maxPrice" placeholder="Do" value="${filters.maxPrice}"></div></div>
                    </div>
                    <div class="products-grid" id="productsGrid"></div>
                </div>
            </div>
        `;
        attachShopEvents(user);
        applyFiltersAndRender();
    }

    function attachShopEvents(user) {
        document.getElementById('homeBtn')?.addEventListener('click', () => { currentView = 'shop'; render(); });
        document.getElementById('profileNav')?.addEventListener('click', () => { currentView = 'profile'; render(); });
        document.getElementById('logoutBtn')?.addEventListener('click', () => { clearCurrent(); currentView = 'shop'; render(); });
        document.getElementById('clearAllFilters')?.addEventListener('click', () => { resetFilters(); render(); });
        document.getElementById('globalSearch')?.addEventListener('input', (e) => { filters.search = e.target.value; applyFiltersAndRender(); });
        document.getElementById('brandSelect')?.addEventListener('change', (e) => { filters.brand = e.target.value; applyFiltersAndRender(); });
        document.getElementById('minPrice')?.addEventListener('input', (e) => { filters.minPrice = e.target.value; applyFiltersAndRender(); });
        document.getElementById('maxPrice')?.addEventListener('input', (e) => { filters.maxPrice = e.target.value; applyFiltersAndRender(); });
        document.querySelectorAll('.ramFilter').forEach(cb => cb.addEventListener('change', () => { filters.ram = Array.from(document.querySelectorAll('.ramFilter:checked')).map(c => c.value); applyFiltersAndRender(); }));
        document.querySelectorAll('.storageFilter').forEach(cb => cb.addEventListener('change', () => { filters.storage = Array.from(document.querySelectorAll('.storageFilter:checked')).map(c => c.value); applyFiltersAndRender(); }));
        document.querySelectorAll('.gpuFilter').forEach(cb => cb.addEventListener('change', () => { filters.gpu = Array.from(document.querySelectorAll('.gpuFilter:checked')).map(c => c.value); applyFiltersAndRender(); }));
        document.querySelectorAll('.screenFilter').forEach(cb => cb.addEventListener('change', () => { filters.screen = Array.from(document.querySelectorAll('.screenFilter:checked')).map(c => c.value); applyFiltersAndRender(); }));
    }

    function resetFilters() {
        filters = { brand: '', ram: [], storage: [], gpu: [], screen: [], minPrice: '', maxPrice: '', search: '' };
    }

    function applyFiltersAndRender() {
        let filtered = [...LAPTOPS];
        if (filters.search) filtered = filtered.filter(p => p.name.toLowerCase().includes(filters.search.toLowerCase()) || p.brand.toLowerCase().includes(filters.search.toLowerCase()));
        if (filters.brand) filtered = filtered.filter(p => p.brand === filters.brand);
        if (filters.ram.length) filtered = filtered.filter(p => filters.ram.includes(p.ram));
        if (filters.storage.length) filtered = filtered.filter(p => filters.storage.includes(p.storage));
        if (filters.gpu.length) filtered = filtered.filter(p => filters.gpu.some(g => p.gpu.includes(g)));
        if (filters.screen.length) filtered = filtered.filter(p => filters.screen.includes(p.screen));
        if (filters.minPrice) filtered = filtered.filter(p => p.price >= parseFloat(filters.minPrice));
        if (filters.maxPrice) filtered = filtered.filter(p => p.price <= parseFloat(filters.maxPrice));
        renderProductList(filtered);
    }

    function renderProductList(products) {
        const grid = document.getElementById('productsGrid');
        if (!grid) return;
        if (products.length === 0) { grid.innerHTML = '<div class="no-results">😢 Nie znaleziono laptopów. Zmień kryteria filtrowania.</div>'; return; }
        grid.innerHTML = products.map(p => `
            <div class="product-card" data-id="${p.id}">
                <div class="product-name">${escapeHtml(p.name)}</div>
                <div class="product-specs">${escapeHtml(p.subtitle)}</div>
                <div class="product-price">${p.price} zł <span style="font-size:14px;">/ miesiąc</span></div>
            </div>
        `).join('');
        document.querySelectorAll('.product-card').forEach(card => {
            card.addEventListener('click', () => {
                selectedProduct = LAPTOPS.find(l => l.id == card.dataset.id);
                currentView = 'product';
                render();
            });
        });
    }

    // ---------- STRONA PRODUKTU ----------
    function renderProductDetail(root, user, product) {
        root.innerHTML = `
            <div class="navbar">
                <div class="logo-area" id="homeBtn"><div class="logo-icon"><div class="ball ball1"></div><div class="ball ball2"></div><div class="ball ball3"></div><div class="ball ball4"></div><div class="ball ball5"></div><div class="center-dot"></div></div><span class="logo-text">CompRent</span></div>
                <div class="nav-links"><button class="nav-link" id="profileNav">Profil</button><div class="user-badge"><span>👋 ${user.name} ${user.surname}</span><button id="logoutBtn" class="logout-btn">Wyloguj</button></div></div>
            </div>
            <div class="container">
                <div class="breadcrumb"><span id="shopBread">Strona główna</span> > Laptop > ${escapeHtml(product.name)}</div>
                <div class="product-detail-card">
                    <div class="product-detail-header"><div><div class="product-detail-title">${escapeHtml(product.name)}</div><div class="rating"><span class="stars">${'★'.repeat(Math.floor(product.rating))}</span> (${product.reviews.length} opinii)</div></div><div><div class="detail-price">${product.price} zł <span style="font-size:16px;">/ miesiąc</span></div><button id="rentProductBtn" class="rent-button">Wypożycz</button></div></div>
                    <div class="specs-table">${Object.entries(product.specs).map(([k,v]) => `<div class="spec-item"><span class="spec-label">${k.charAt(0).toUpperCase()+k.slice(1)}:</span> ${v}</div>`).join('')}</div>
                    <div class="product-description"><strong>Opis towaru</strong><br>${product.description}</div>
                </div>
                <div class="reviews-block"><div class="product-detail-title" style="font-size:22px;">Opinie</div>${product.reviews.map(r => `<div class="review-item"><div><strong>${r.author}</strong> <span class="stars">${'★'.repeat(r.rating)}</span></div><div>${r.text}</div></div>`).join('')}${product.reviews.length===0?'<div style="padding:20px 0;">Brak opinii, bądź pierwszy!</div>':''}</div>
            </div>
        `;
        document.getElementById('homeBtn')?.addEventListener('click', () => { currentView = 'shop'; render(); });
        document.getElementById('shopBread')?.addEventListener('click', () => { currentView = 'shop'; render(); });
        document.getElementById('profileNav')?.addEventListener('click', () => { currentView = 'profile'; render(); });
        document.getElementById('logoutBtn')?.addEventListener('click', () => { clearCurrent(); currentView = 'shop'; render(); });
        document.getElementById('rentProductBtn')?.addEventListener('click', () => alert('📦 Produkt został dodany do wypożyczenia. Dziękujemy!'));
    }

    // ---------- PROFIL UŻYTKOWNIKA ----------
    function renderProfile(root, user) {
        root.innerHTML = `
            <div class="navbar">
                <div class="logo-area" id="homeBtn"><div class="logo-icon"><div class="ball ball1"></div><div class="ball ball2"></div><div class="ball ball3"></div><div class="ball ball4"></div><div class="ball ball5"></div><div class="center-dot"></div></div><span class="logo-text">CompRent</span></div>
                <div class="nav-links"><button class="nav-link" id="profileNav" style="color:#1f6392;">Profil</button><div class="user-badge"><span>👋 ${user.name} ${user.surname}</span><button id="logoutBtn" class="logout-btn">Wyloguj</button></div></div>
            </div>
            <div class="container">
                <div class="breadcrumb"><span id="shopBread">Strona główna</span> > Profil</div>
                <div class="profile-card">
                    <div class="product-detail-title">Twoje konto</div>
                    <div class="profile-tabs"><button class="profile-tab active" data-tab="account">Dane osobowe</button><button class="profile-tab" data-tab="orders">Zamówienia</button></div>
                    <div id="accountTab"><div class="form-double"><div class="input-field"><label>Imię</label><input id="profileName" value="${user.name}"></div><div class="input-field"><label>Nazwisko</label><input id="profileSurname" value="${user.surname}"></div><div class="input-field"><label>Email</label><input id="profileEmail" value="${user.email}"></div><div class="input-field"><label>Adres</label><input id="profileAddress" value="${user.address||''}"></div><div class="input-field"><label>Kod pocztowy</label><input id="profilePostal" value="${user.postal||''}"></div><div class="input-field"><label>Telefon</label><input id="profilePhone" value="${user.phone||''}"></div></div><button id="saveProfile" class="save-button">Zapisz zmiany</button><div class="password-change"><div class="product-detail-title" style="font-size:18px;">Zmień hasło</div><div class="form-double"><div class="input-field"><label>Obecne hasło</label><input type="password" id="currentPass"></div><div class="input-field"><label>Nowe hasło</label><input type="password" id="newPass"></div></div><button id="changePassword" class="save-button">Zmień hasło</button></div></div>
                    <div id="ordersTab" style="display:none;"><div style="padding:40px; text-align:center; color:#6c7f96;">📭 Nie masz jeszcze żadnych zamówień</div></div>
                </div>
            </div>
        `;
        document.getElementById('homeBtn')?.addEventListener('click', () => { currentView = 'shop'; render(); });
        document.getElementById('shopBread')?.addEventListener('click', () => { currentView = 'shop'; render(); });
        document.getElementById('profileNav')?.addEventListener('click', () => { currentView = 'profile'; render(); });
        document.getElementById('logoutBtn')?.addEventListener('click', () => { clearCurrent(); currentView = 'shop'; render(); });
        document.querySelectorAll('.profile-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                document.getElementById('accountTab').style.display = tab.dataset.tab === 'account' ? 'block' : 'none';
                document.getElementById('ordersTab').style.display = tab.dataset.tab === 'orders' ? 'block' : 'none';
            });
        });
        document.getElementById('saveProfile')?.addEventListener('click', () => {
            const users = getUsers();
            const idx = users.findIndex(u => u.id === user.id);
            if (idx !== -1) {
                users[idx].name = document.getElementById('profileName').value;
                users[idx].surname = document.getElementById('profileSurname').value;
                users[idx].email = document.getElementById('profileEmail').value;
                users[idx].address = document.getElementById('profileAddress').value;
                users[idx].postal = document.getElementById('profilePostal').value;
                users[idx].phone = document.getElementById('profilePhone').value;
                saveUsers(users);
                setCurrent(users[idx]);
                alert('✅ Dane zostały zaktualizowane');
                render();
            }
        });
        document.getElementById('changePassword')?.addEventListener('click', () => {
            const current = document.getElementById('currentPass').value;
            const newPwd = document.getElementById('newPass').value;
            if (current !== user.password) { alert('❌ Obecne hasło jest nieprawidłowe'); return; }
            if (!newPwd) { alert('Wprowadź nowe hasło'); return; }
            const users = getUsers();
            const idx = users.findIndex(u => u.id === user.id);
            users[idx].password = newPwd;
            saveUsers(users);
            setCurrent(users[idx]);
            alert('🔒 Hasło zostało zmienione');
            document.getElementById('currentPass').value = '';
            document.getElementById('newPass').value = '';
        });
    }

    function escapeHtml(str) { return String(str).replace(/[&<>]/g, function(m) { if (m === '&') return '&amp;'; if (m === '<') return '&lt;'; if (m === '>') return '&gt;'; return m; }); }

    initDB();
    render();
</script>
</body>
</html>
